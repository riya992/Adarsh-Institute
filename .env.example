# Required for Adarsh AI chatbot.
# Add this in Netlify Site configuration -> Environment variables too.
GEMINI_API_KEY="your-gemini-api-key"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Supabase: server-only values for saving and reading enquiries.
# In Netlify, add these in Site configuration -> Environment variables.
SUPABASE_URL="https://your-project.supabase.co"

# Admin panel password.
ADMIN_PASSWORD="change-this-password"

# Required for enquiry submit and admin reads securely from the server.
# Get this from Supabase Dashboard -> Project Settings -> API -> service_role secret.
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"
